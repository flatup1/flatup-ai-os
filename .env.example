# --- OpenRouter (本番 LINE Bot と同じスタック) ---
OPENROUTER_API_KEY=

# 本番 LINE Bot と同じ Haiku 4.5。安く・速く・thinkingなし。
# 強化したい場合のみ anthropic/claude-sonnet-4.6 などに差し替え。
AIKA_MODEL=anthropic/claude-haiku-4-5

# OpenRouter エンドポイント。通常は変更不要。
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter のアトリビューションヘッダ(本番に合わせる)
OPENROUTER_REFERER=https://line.flatupnarita.jp
OPENROUTER_TITLE=FLATUP AI OS

# 出力トークン上限。LINE 短文返信なら 250、マニュアル・台本は 4096〜8000。
AIKA_MAX_TOKENS=4096

# サンプリング温度(本番と揃えるなら 0.4)
AIKA_TEMPERATURE=0.4

# 出力をファイルに自動保存するか
AIKA_LOG_OUTPUT=true

# --- PII サニタイズ ---
# 本番 LINE Bot (line_webhook.py) と同じく「ログ保存時のみ部分マスク」が既定。
# 標準出力やオーナー画面はそのまま見える(レビューしやすさ重視)。

# 全体オフ(デバッグ用、通常は true のまま)
AIKA_SANITIZE_PII=true

# AI 投入前もマスクするか。true にすると AI が元の電話番号等を見られなくなる(安全寄り)。
AIKA_SANITIZE_BEFORE_AI=false

# ログのマスクスタイル。
#   partial: 090-****-5678 / t****@example.com(本番互換、人間がレビューしやすい)
#   redact:  [phone] / [email](完全消去)
AIKA_PII_STYLE=partial

# 「田中さん」「鈴木様」など氏名+敬称もマスクする(誤検知あり、opt-in)。
AIKA_SANITIZE_NAMES=false

# --- Typefully / X投稿 ---
# Typefully APIキーはこの .env に書かない。
# /Users/jin/.config/typefully/config.json に chmod 600 で保存する。
# default social set ID: 307036

# --- 動物×格闘技リール量産 (Seedance 2.0 via fal.ai) ---
# 取得: https://fal.ai/dashboard/keys 。未設定なら npm run reel は DRY-RUN(コストゼロ)。
FAL_KEY=

# 生成エンドポイント。既定は安い Fast 層。品質重視の決定版だけ切り替える:
#   bytedance/seedance-2.0/fast/text-to-video (既定・安い)
#   bytedance/seedance-2.0/text-to-video      (高品質・高い)
SEEDANCE_ENDPOINT=bytedance/seedance-2.0/fast/text-to-video

# 解像度(480p/720p)と秒数(4〜15)
SEEDANCE_RESOLUTION=720p
SEEDANCE_DURATION=6
