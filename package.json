{
  "name": "flatup-ai-os",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "FLATUP GYM の AI スタッフ「AIKA」を Claude で動かすための運用 OS",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "list": "tsx src/index.ts --list",
    "test:safety": "tsx src/safety/receptionist.test.ts",
    "test:pii": "tsx src/utils/sanitizePii.test.ts",
    "test:routes": "OPENROUTER_API_KEY= tsx src/test/routes.test.ts",
    "test:customers": "tsx src/modules/customers.test.ts",
    "test": "npm run typecheck && npm run test:safety && npm run test:pii && npm run test:routes && npm run test:customers"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
